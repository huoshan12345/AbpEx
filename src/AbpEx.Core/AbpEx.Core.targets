<Project>
  <Target Name="AddAbpCoreAlias" BeforeTargets="FindReferenceAssembliesForReferences;ResolveReferences"
          Condition="'$(AbpExDisableAbpCoreAlias)' != 'true'">
    <ItemGroup>
      <ReferencePath Condition="'%(FileName)' == 'Volo.Abp.Core'">
        <Aliases>AbpCore</Aliases>
      </ReferencePath>
    </ItemGroup>
  </Target>
</Project>